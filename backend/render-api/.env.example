# ── RenderJobsAPI Configuration ──────────────────────────────────
# Copy this file to .env and fill in the values.

# Server port
PORT=4000

# API key for authenticating requests from the Lovable frontend.
VIDEO_PIPELINE_API_KEY=

# Webhook secret for status update callbacks.
OVH_RENDER_WEBHOOK_SECRET=

# CORS origin (set to your Lovable app URL in production)
CORS_ORIGIN=https://ytcreator.lovable.app

# Path to store job JSON files
RENDER_JOBS_STORAGE_PATH=/app/data/jobs

# ── Remotion ─────────────────────────────────────────────────────

# Enable/disable the background renderer (set false for API-only mode)
ENABLE_RENDERER=true

# Pre-bundled serve URL (leave empty to auto-bundle at startup)
REMOTION_SERVE_URL=

# Remotion composition ID
REMOTION_COMPOSITION_ID=video-prompt

# Output directory for rendered MP4 files
REMOTION_OUTPUT_DIR=/app/data/renders

# Render timeout in milliseconds (default: 5 minutes)
REMOTION_TIMEOUT_MS=300000

# Worker polling interval in milliseconds
RENDER_POLL_INTERVAL_MS=5000

# Max concurrent renders (increase based on server resources)
RENDER_MAX_CONCURRENT=1

# Public base URL for rendered file access (e.g. https://render.yourdomain.com)
PUBLIC_RENDER_URL=

# Chromium path (set by Dockerfile, override if needed)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
